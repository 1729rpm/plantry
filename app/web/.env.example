# Convex deployment URL the frontend reads at build time.
# Get this from the Convex dashboard after running `npx convex dev` in app/convex.
# Example: https://earnest-mosquito-123.convex.cloud
VITE_CONVEX_URL=

# Shared splash-gate passcode. Until this is entered, the app stays on the
# passcode screen. Stored client-side only; no server validation.
# Pick anything non-empty for local dev.
VITE_PLANTRY_PASSCODE=
