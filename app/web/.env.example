# Convex deployment URL the frontend reads at build time.
# Get this from the Convex dashboard after running `npx convex dev` in app/convex.
# Example: https://earnest-mosquito-123.convex.cloud
VITE_CONVEX_URL=

# Whether to gate the splash with the shared passcode.
# Set to "true" in production; "false" for local dev.
VITE_APP_PASSCODE_REQUIRED=false
